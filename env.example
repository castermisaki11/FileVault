# ════════════════════════════════════════
#  FileVault — .env.example
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ════════════════════════════════════════

# ── Server ──────────────────────────────
PORT=3000
FV_STORAGE_LIMIT=5gb
FV_FILE_LIMIT=200mb
FV_SITE_PASSWORD=
FV_SHUTDOWN_TOKEN=

# ── PostgreSQL ───────────────────────────
# รูปแบบ: postgresql://user:password@host:5432/dbname
DATABASE_URL=
# DB_SSL=auto       # auto | true | false (auto=เปิด SSL เมื่อไม่ใช่ localhost)
# DB_POOL_MAX=10    # จำนวน connection สูงสุด
# DB_POOL_IDLE_MS=30000

# ── Cloudflare R2 ────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
FV_DEFAULT_FOLDER=cloud

# ════════════════════════════════════════
#  Bot 1 — FileVault Bot (R2 + auto-upload)
#  รัน: node bot.js  หรือ  npm run bot
# ════════════════════════════════════════
DISCORD_TOKEN=          # Token ของ FileVault Bot
DISCORD_CLIENT_ID=      # Application ID ของ FileVault Bot
CHANNEL_ID=             # Channel ID สำหรับ auto-upload ไฟล์
DISCORD_ADMIN_IDS=      # User IDs ที่เป็น admin (คั่นด้วย ,)
DISCORD_IMAGE_FOLDER=discord-images
DISCORD_FILE_FOLDER=discord-files
FV_SERVER_URL=http://localhost:3000

# ════════════════════════════════════════
#  Bot 2 — Management Bot (ticket, kick, ban ฯลฯ)
#  รัน: node discord/Bot2.js  หรือ  npm run bot2
# ════════════════════════════════════════
DISCORD_TOKEN2=         # Token ของ Management Bot (คนละ bot กับ Bot 1)
CLIENT_ID2=             # Application ID ของ Management Bot

# Role IDs
STAFF_ROLE_ID=          # Role ID ของ Staff
ADMIN_ROLE_ID=          # Role ID ของ Admin

# Channel IDs
LOG_CHANNEL_ID=         # Channel สำหรับ log event ทั่วไป
LOG_CHANNEL_IDTICK=     # Channel สำหรับ log ticket

# Ticket System
TICKET_CATEGORY_ID=     # Category ID สำหรับสร้าง ticket channels

# Reaction Roles (emoji → Role ID)
REACTION_ROLE_MESSAGE_ID=   # Message ID ของ reaction role message
ROLE_GAMER=             # Role ID สำหรับ emoji 🎮
ROLE_BOT=               # Role ID สำหรับ emoji 👾
ROLE_NOT=               # Role ID สำหรับ emoji 🎵
ROLE_VIP=               # Role ID สำหรับ emoji 🌟
