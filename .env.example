# ── Server ──────────────────────────────────────────────────
FV_PORT=3000
FV_STORAGE_LIMIT=0           # 0 = unlimited | เช่น 5gb, 500mb
FV_FILE_LIMIT=200mb
FV_STATUS_MS=5000
FV_SITE_PASSWORD=            # ว่าง = ไม่ล็อค
FV_DEFAULT_FOLDER=upload/cloud
FV_SHUTDOWN_TOKEN=           # ว่าง = ไม่ต้องใช้ token

# ── Cloudflare R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=               # optional: https://cdn.yourdomain.com

# ── Stats Sync ───────────────────────────────────────────────
FV_STATS_KEY=system/stats.json
FV_STATS_SYNC_MS=15000

# ── Discord Bot (FileVault) ───────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
CHANNEL_ID=
DISCORD_ADMIN_IDS=           # user IDs คั่นด้วย comma: 123,456
DISCORD_IMAGE_FOLDER=discord-images
DISCORD_FILE_FOLDER=discord-files
DOMAIN=                      # https://yourdomain.com

# ── Discord Bot (Monitor) — optional ─────────────────────────
MTDISCORD_TOKEN=
DISCORD_CLIENT_ID2=
MTDISCORD_CHANNEL_ID=
MONITOR_URLS=                # comma-separated: https://site1.com,https://site2.com
