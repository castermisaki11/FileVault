# ── Server ──────────────────────────────
FV_PORT=3000
FV_STORAGE_LIMIT=5gb          # 0 = unlimited
FV_FILE_LIMIT=200mb
FV_STATUS_MS=5000

# ── Site Password (optional) ────────────
# ถ้าตั้งค่านี้ ผู้เข้าชมต้องใส่รหัสก่อนเข้าเว็บ
FV_SITE_PASSWORD=

# ── Default Upload Folder ───────────────
# ไฟล์ที่ upload จาก root จะเข้า folder นี้ใน R2
FV_DEFAULT_FOLDER=uploads

# ── Cloudflare R2 ────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_URL=https://your-domain.com   # optional, custom domain

# ── Discord Bot ──────────────────────────
DISCORD_TOKEN=your_bot_token
CHANNEL_ID=your_channel_id
DOMAIN=https://your-domain.com          # optional, shown in status embed

# โฟลเดอร์ใน R2 ที่รูปจาก Discord จะถูก upload ไป
DISCORD_IMAGE_FOLDER=discord-images
